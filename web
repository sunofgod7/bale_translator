async function isChannelMember(token: string, userId: number): Promise<boolean> {
  try {
    const res = await safeFetch(`${BALE_API}/bot${token}/getChatMember`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: REQUIRED_CHANNEL, user_id: userId }),
    });
    const txt = await res.text();
    let j: any;
    try { j = JSON.parse(txt); } catch { return false; }
    if (!j?.ok) return false;
    const status = j?.result?.status;
    return status === "member" || status === "administrator" || status === "creator" || status === "owner";
  } catch (e) {
    console.error("[bale] isChannelMember failed", e);
    return false;
  }
}

