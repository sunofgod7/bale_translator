// ---------- TTS (English pronunciation) ----------
// Stateless: we encode the source of the English text into callback_data,
// and read the actual text from the callback message itself (no in-memory store
// — workers are stateless across invocations).
//
// Modes:
//   tts:src  -> English text is in cq.message.reply_to_message.text (user's original message)
//   tts:msg  -> English text is in cq.message.text after the EN_MARKER line
const EN_MARKER = "🔤 EN:";
function ttsKeyboard(mode: "src" | "msg" = "src") {
  return {
    inline_keyboard: [
      [{ text: "🔊 شنیدن تلفظ انگلیسی", callback_data: `tts:${mode}` }],
      [{ text: "📚 مترادف و متضاد", callback_data: `syn:${mode}` }],
    ],
  };
}
function synOnlyKeyboard() {
  return { inline_keyboard: [[{ text: "📚 مترادف و متضاد", callback_data: "syn:src" }]] };
}
function extractEnglishFromCallbackMessage(cqMessage: any, mode: string): string | null {
  if (mode === "src") {
    const t = cqMessage?.reply_to_message?.text;
    return typeof t === "string" && t.trim() ? t.trim() : null;
  }
  if (mode === "msg") {
    const t: string = cqMessage?.text ?? "";
    const idx = t.indexOf(EN_MARKER);
    if (idx === -1) return null;
    const after = t.slice(idx + EN_MARKER.length).trim();
    // Strip trailing helper line if present
    const stop = after.indexOf("\n\n");
    return (stop === -1 ? after : after.slice(0, stop)).trim() || null;
  }
  return null;
}

function chunkForTts(text: string, max = 190): string[] {
  const clean = text.replace(/\s+/g, " ").trim();
  if (!clean) return [];
  const parts: string[] = [];
  const sentences = clean.split(/(?<=[.!?])\s+/);
  let buf = "";
  for (const s of sentences) {
    if (s.length > max) {
      if (buf) { parts.push(buf); buf = ""; }
      const words = s.split(" ");
      let cur = "";
      for (const w of words) {
        if ((cur + " " + w).trim().length > max) {
          if (cur) parts.push(cur);
          cur = w;
        } else {
          cur = (cur ? cur + " " : "") + w;
        }
      }
      if (cur) parts.push(cur);
    } else if ((buf + " " + s).trim().length > max) {
      if (buf) parts.push(buf);
      buf = s;
    } else {
      buf = (buf ? buf + " " : "") + s;
    }
  }
  if (buf) parts.push(buf);
  return parts;
}

async function googleTts(text: string): Promise<Uint8Array> {
  const chunks = chunkForTts(text);
  if (chunks.length === 0) throw new Error("متنی برای تلفظ پیدا نشد.");
  const buffers: Uint8Array[] = [];
  for (const c of chunks) {
    const url = `https://translate.google.com/translate_tts?ie=UTF-8&tl=en&client=tw-ob&q=${encodeURIComponent(c)}`;
    const res = await safeFetch(url, {
      headers: {
        "User-Agent":
          "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36",
        "Referer": "https://translate.google.com/",
      },
    });
    if (!res.ok) throw new Error(`خطا در دریافت صوت (${res.status})`);
    buffers.push(new Uint8Array(await res.arrayBuffer()));
  }
  let total = 0;
  for (const b of buffers) total += b.length;
  const out = new Uint8Array(total);
  let off = 0;
  for (const b of buffers) { out.set(b, off); off += b.length; }
  return out;
}

async function sendPronunciation(token: string, chatId: number, englishText: string, replyTo?: number) {
  const trimmed = englishText.trim().slice(0, 1500);
  if (!trimmed) {
    await sendMessage(token, chatId, "متنی برای تلفظ نیست.", replyTo);
