export const Route = createFileRoute("/api/public/bale-webhook")({
  server: {
    handlers: {
      POST: async ({ request }) => {
        // Outer guard so bot never returns 5xx to Bale (Bale would keep retrying)
        try {
          const token = process.env.BALE_BOT_TOKEN;
          if (!token) {
            console.error("BALE_BOT_TOKEN not configured");
            return new Response("ok");
          }

          let update: any;
          try { update = await request.json(); }
          catch (e) { console.error("invalid update json", e); return new Response("ok"); }

          // Inline-keyboard callback (TTS pronunciation + channel verify)
          if (update?.callback_query) {
            const cq = update.callback_query;
            const cbChatId = cq.message?.chat?.id;
            const cbMsgId = cq.message?.message_id;
            const cbUserId = cq.from?.id;
            const dataStr: string = typeof cq.data === "string" ? cq.data : "";
            try {
              if (dataStr === "verify" && cbChatId && cbUserId) {
                const ok = await isChannelMember(token, cbUserId);
                if (ok) {
                  await answerCallbackQuery(token, cq.id, "✅ عضویت تایید شد");
                  await sendMessage(
                    token,
                    cbChatId,
                    "عالی! حالا می‌تونی از ربات استفاده کنی 🎉\nبرام بفرست تا به فارسی ترجمه کنم:\n• 📝 متن انگلیسی\n• 🖼 تصویر حاوی متن انگلیسی\n• 🎙 پیام صوتی یا فایل صوتی انگلیسی\n• 🎬 ویدیو انگلیسی (.srt فارسی)\n\n🧪 تحلیل آزمایش پزشکی: عکس برگه‌ی آزمایش رو با کپشن «تحلیل» بفرست.",
                  );
                } else {
                  await answerCallbackQuery(token, cq.id, "❌ هنوز عضو نیستی");
                  await sendJoinPrompt(token, cbChatId, cbMsgId);
                }
                return new Response("ok");
              }
              if (dataStr.startsWith("tts:") && cbChatId) {
                // Gate TTS callback too
                if (cbUserId && !(await isChannelMember(token, cbUserId))) {
                  await answerCallbackQuery(token, cq.id, "ابتدا در کانال عضو شو");
                  await sendJoinPrompt(token, cbChatId, cbMsgId);
                  return new Response("ok");
                }
                const mode = dataStr.slice(4);
                const text = extractEnglishFromCallbackMessage(cq.message, mode);
                if (!text) {
                  await answerCallbackQuery(token, cq.id, "متن پیدا نشد. دوباره بفرست.");
                } else {
                  await answerCallbackQuery(token, cq.id, "در حال ساخت تلفظ…");
                  try {
                    await sendPronunciation(token, cbChatId, text, cbMsgId);
                  } catch (e) {
                    const detail = e instanceof Error ? e.message : String(e);
                    console.error("tts error", detail);
                    await sendMessage(token, cbChatId, `خطا در ساخت تلفظ: ${detail.slice(0, 300)}`, cbMsgId);
                  }
                }
              } else if (dataStr.startsWith("syn:") && cbChatId) {
                if (cbUserId && !(await isChannelMember(token, cbUserId))) {
                  await answerCallbackQuery(token, cq.id, "ابتدا در کانال عضو شو");
                  await sendJoinPrompt(token, cbChatId, cbMsgId);
                  return new Response("ok");
                }
                const mode = dataStr.slice(4);
                const text = extractEnglishFromCallbackMessage(cq.message, mode);
                if (!text) {
                  await answerCallbackQuery(token, cq.id, "کلمه‌ای پیدا نشد.");
                } else {
                  await answerCallbackQuery(token, cq.id, "در حال یافتن مترادف…");
                  try {
                    const out = await synonymsAndAntonym(text);
                    await sendLongMessage(token, cbChatId, out || "نتیجه‌ای دریافت نشد.", cbMsgId);
                  } catch (e) {
                    const detail = e instanceof Error ? e.message : String(e);
                    console.error("syn error", detail);
                    await sendMessage(token, cbChatId, `خطا در یافتن مترادف: ${detail.slice(0, 300)}`, cbMsgId);
                  }
                }
              } else {
                await answerCallbackQuery(token, cq.id);
              }
            } catch (e) { console.error("callback_query error", e); }
            return new Response("ok");
          }

          const msg = update?.message ?? update?.edited_message ?? update?.channel_post;
          if (!msg) return new Response("ok");
          const chatId = msg.chat?.id;
          const msgId = msg.message_id;
          const fromUserId = msg.from?.id;
          if (!chatId) return new Response("ok");

          // Channel membership gate — only for private chats (skip groups/channels)
          const chatType = msg.chat?.type;
          if ((chatType === "private" || !chatType) && fromUserId) {
            try {
              const ok = await isChannelMember(token, fromUserId);
              if (!ok) {
                await sendJoinPrompt(token, chatId, msgId);
                return new Response("ok");
              }
            } catch (e) { console.error("membership check failed", e); }
          }


          try {
            // /start
            if (typeof msg.text === "string" && msg.text.startsWith("/start")) {
              await sendMessage(
                token,
                chatId,
                "سلام! 👋\nبرام بفرست تا به فارسی ترجمه کنم:\n• 📝 متن انگلیسی\n• 🖼 تصویر حاوی متن انگلیسی\n• 🎙 پیام صوتی یا فایل صوتی انگلیسی\n• 🎬 ویدیو انگلیسی (فایل زیرنویس .srt فارسی تحویل می‌گیری)\n\n🧪 تحلیل آزمایش پزشکی:\nعکس برگه‌ی آزمایش رو بفرست و توی کپشن بنویس «تحلیل» یا «آزمایش» (یا اول /analyze رو بزن).\n\n📚 مترادف و متضاد کلمه:\nبنویس: «مترادف <کلمه>» یا از دکمه‌ی زیر ترجمه‌ی متن استفاده کن. مثلاً: مترادف happy",
              );
              return new Response("ok");
            }

            // /analyze command
            if (typeof msg.text === "string" && (msg.text.startsWith("/analyze") || msg.text.startsWith("/test"))) {
              await sendMessage(
                token,
                chatId,
                "🧪 حالت تحلیل آزمایش\nلطفاً عکس برگه‌ی آزمایشت رو بفرست و توی کپشنش بنویس: «تحلیل»\n(هرچی واضح‌تر و باکیفیت‌تر، تحلیل دقیق‌تر)",
              );
              return new Response("ok");
            }

            // /synonyms command or "مترادف <word>" prefix
            if (typeof msg.text === "string") {
              const t = msg.text.trim();
              const lower = t.toLowerCase();
              let word = "";
              if (lower.startsWith("/synonyms") || lower.startsWith("/syn")) {
                word = t.replace(/^\/syn(onyms)?\s*/i, "").trim();
              } else if (t.startsWith("مترادف")) {
                word = t.replace(/^مترادف[:\s]*/, "").trim();
              }
              if (lower === "/synonyms" || lower === "/syn" || t === "مترادف") {
                await sendMessage(
                  token,
                  chatId,
                  "📚 حالت مترادف و متضاد\nکلمه‌ی موردنظرتو بنویس، مثلاً:\n«مترادف happy»\nیا فقط بنویس: happy و بعد روی دکمه «📚 مترادف و متضاد» بزن.",
                );
                return new Response("ok");
              }
              if (word) {
                try {
                  const out = await synonymsAndAntonym(word);
                  await sendLongMessage(token, chatId, out || "نتیجه‌ای دریافت نشد.", msgId);
                } catch (e) {
                  const detail = e instanceof Error ? e.message : String(e);
                  console.error("syn cmd error", detail);
                  await sendMessage(token, chatId, `خطا در یافتن مترادف: ${detail.slice(0, 300)}`, msgId);
                }
                return new Response("ok");
              }
            }

            // Voice / Audio → SRT
            const audio = msg.voice || msg.audio;
            if (audio?.file_id) {
              await sendMessage(token, chatId, "در حال رونویسی صوت و ساخت زیرنویس فارسی… ⏳ (ممکنه چند ثانیه طول بکشه)", msgId);
              try {
                const { srt, preview } = await transcribeAndTranslateMedia(token, audio.file_id, "audio");
                const encoder = new TextEncoder();
                const bytes = encoder.encode("\uFEFF" + srt);
                await sendDocument(token, chatId, "translation_fa.srt", bytes, "application/x-subrip", "زیرنویس فارسی ✅", msgId);
                if (preview) await sendMessage(token, chatId, `پیش‌نمایش ترجمه:\n${preview}`, msgId);
              } catch (e) {
                const detail = e instanceof Error ? e.message : String(e);
                console.error("audio error", detail);
                await sendMessage(token, chatId, `خطا در پردازش صوت: ${detail.slice(0, 400)}`, msgId);
              }
              return new Response("ok");
            }

            // Video → SRT (msg.video or msg.video_note)
            const video = msg.video || msg.video_note;
            if (video?.file_id) {
              await sendMessage(token, chatId, "در حال پردازش ویدیو و ساخت زیرنویس فارسی… ⏳ (ممکنه کمی طول بکشه)", msgId);
              try {
                const { srt, preview } = await transcribeAndTranslateMedia(token, video.file_id, "video");
                const bytes = new TextEncoder().encode("\uFEFF" + srt);
                await sendDocument(token, chatId, "translation_fa.srt", bytes, "application/x-subrip", "زیرنویس فارسی ✅", msgId);
                if (preview) await sendMessage(token, chatId, `پیش‌نمایش ترجمه:\n${preview}`, msgId);
              } catch (e) {
                const detail = e instanceof Error ? e.message : String(e);
                console.error("video error", detail);
                await sendMessage(token, chatId, `خطا در پردازش ویدیو: ${detail.slice(0, 400)}`, msgId);
              }
              return new Response("ok");
            }

            // Photo
            if (Array.isArray(msg.photo) && msg.photo.length > 0) {
              const largest = msg.photo[msg.photo.length - 1];
              const analyze = wantsAnalysis(msg.caption);
              await sendMessage(
                token,
                chatId,
                analyze ? "در حال تحلیل برگه‌ی آزمایش… 🧪⏳ (ممکنه چند ثانیه طول بکشه)" : "در حال خواندن تصویر و ترجمه… ⏳",
                msgId,
              );
              try {
                if (analyze) {
                  const analysis = await analyzeLabTestImage(token, largest.file_id);
                  await sendLongMessage(token, chatId, analysis || "تحلیلی دریافت نشد.", msgId);
                } else {
                  const translation = await translateImage(token, largest.file_id);
                  await sendMessage(token, chatId, translation || "ترجمه‌ای دریافت نشد.", msgId);
                  // Offer pronunciation of the English text in the image
                  try {
                    const english = await extractEnglishFromImage(token, largest.file_id);
                    if (english && english.length > 1) {
                      const body = `می‌خوای تلفظ انگلیسی متن داخل تصویرو بشنوی؟ 🔊\n\n${EN_MARKER} ${english}`;
                      await sendMessage(token, chatId, body, msgId, ttsKeyboard("msg"));
                    }
                  } catch (e) { console.error("english extract error", e); }
                }
              } catch (e) {
                const detail = e instanceof Error ? e.message : String(e);
                console.error("image error", detail);
                await sendMessage(token, chatId, `${analyze ? "خطا در تحلیل آزمایش" : "خطا در ترجمه تصویر"}: ${detail.slice(0, 400)}`, msgId);
              }
              return new Response("ok");
            }

            // Text
            if (typeof msg.text === "string" && msg.text.trim()) {
              const src = msg.text.trim();
              try {
                const translation = await translateText(src);
                // Decide which side is English: if src is mostly Latin letters, src is English; otherwise translation is.
                const latinRatio = (src.match(/[A-Za-z]/g)?.length ?? 0) / Math.max(src.length, 1);
                const english = latinRatio > 0.4 ? src : (translation || "");
                const body = `${translation || "ترجمه‌ای دریافت نشد."}\n\n${EN_MARKER} ${english}`;
                await sendMessage(token, chatId, body, msgId, ttsKeyboard("msg"));
              } catch (e) {
                const detail = e instanceof Error ? e.message : String(e);
                console.error("text error", detail);
                await sendMessage(token, chatId, `خطا در ترجمه: ${detail.slice(0, 400)}`, msgId);
              }
              return new Response("ok");
            }

            // Document containing audio or video
            const docMime = typeof msg.document?.mime_type === "string" ? msg.document.mime_type : "";
            if (msg.document?.file_id && (docMime.startsWith("audio/") || docMime.startsWith("video/"))) {
              const kind: "audio" | "video" = docMime.startsWith("video/") ? "video" : "audio";
              await sendMessage(token, chatId, kind === "video"
                ? "در حال پردازش فایل ویدیو و ساخت زیرنویس فارسی… ⏳"
                : "در حال رونویسی فایل صوتی و ساخت زیرنویس فارسی… ⏳", msgId);
              try {
                const { srt, preview } = await transcribeAndTranslateMedia(token, msg.document.file_id, kind);
                const bytes = new TextEncoder().encode("\uFEFF" + srt);
                await sendDocument(token, chatId, "translation_fa.srt", bytes, "application/x-subrip", "زیرنویس فارسی ✅", msgId);
                if (preview) await sendMessage(token, chatId, `پیش‌نمایش ترجمه:\n${preview}`, msgId);
              } catch (e) {
                const detail = e instanceof Error ? e.message : String(e);
                console.error("media-doc error", detail);
                await sendMessage(token, chatId, `خطا در پردازش فایل: ${detail.slice(0, 400)}`, msgId);
              }
              return new Response("ok");
            }

            await sendMessage(token, chatId, "لطفاً متن، تصویر، صوت یا ویدیوی انگلیسی بفرست.", msgId);
            return new Response("ok");

          } catch (innerErr) {
            const detail = innerErr instanceof Error ? innerErr.message : String(innerErr);
            console.error("inner handler error", detail, innerErr);
            await sendMessage(token, chatId, `یه خطای غیرمنتظره رخ داد: ${detail.slice(0, 300)}`, msgId);
            return new Response("ok");
          }
        } catch (fatal) {
          // Never let the worker crash the webhook — always 200 OK to Bale
          console.error("FATAL bale-webhook error", fatal);
          return new Response("ok");
        }
      },
      GET: async () => new Response("Bale translator webhook is alive"),
    },
  },
});