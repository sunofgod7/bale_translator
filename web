async function getFileBytes(token: string, fileId: string): Promise<{ bytes: Uint8Array; mime: string; path: string }> {
  const fileRes = await safeFetch(`${BALE_API}/bot${token}/getFile?file_id=${fileId}`);
  const fileText = await fileRes.text();
  let fileJson: any;
  try { fileJson = JSON.parse(fileText); } catch { throw new Error(`getFile non-JSON: ${fileText.slice(0, 200)}`); }
  const filePath = fileJson?.result?.file_path;
  if (!filePath) throw new Error(`No file_path: ${fileText.slice(0, 200)}`);

  const imgRes = await safeFetch(`${BALE_API}/file/bot${token}/${filePath}`);
  if (!imgRes.ok) throw new Error(`download failed ${imgRes.status}`);
  const bytes = new Uint8Array(await imgRes.arrayBuffer());
  let mime = imgRes.headers.get("content-type")?.split(";")[0]?.trim() || "";
  return { bytes, mime, path: filePath };
}

function toBase64(buf: Uint8Array): string {
  let binary = "";
  const CHUNK = 0x8000;
  for (let i = 0; i < buf.length; i += CHUNK) {
    binary += String.fromCharCode.apply(null, buf.subarray(i, i + CHUNK) as unknown as number[]);
  }
  return btoa(binary);
}

function guessMime(path: string, current: string, fallback: string, map: Record<string, string>): string {
  let mime = current;
  if (!mime || mime === "application/octet-stream") {
    const ext = path.split(".").pop()?.toLowerCase();
    mime = (ext && map[ext]) || fallback;
  }
  return mime;
}

// ---------- AI calls ----------
async function gateway(body: unknown): Promise<any> {
  const apiKey = process.env.LOVABLE_API_KEY;
  if (!apiKey) throw new Error("LOVABLE_API_KEY not configured");
  const res = await safeFetch(GATEWAY, {
    method: "POST",
    headers: { Authorization: `Bearer ${apiKey}`, "Content-Type": "application/json" },
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const t = await res.text();
    if (res.status === 429) throw new Error("سرویس ترجمه شلوغه. چند لحظه دیگه دوباره امتحان کن.");
    if (res.status === 402) throw new Error("اعتبار سرویس ترجمه تموم شده. لطفاً به ادمین اطلاع بده.");
    throw new Error(`AI gateway ${res.status}: ${t.slice(0, 300)}`);
  }
  return res.json();
}

